# Copy thành .env và điền giá trị thật (tham khảo TaiLieu.txt)
BOT_TOKEN=
SHOP_NAME=Văn Minh Store

GSHEET_ID=
GSVC_JSON=telegram-bot-gsheet.json
# Render: dán toàn bộ nội dung file service account JSON (1 dòng)
GOOGLE_JSON_CONTENT=

# Render tự gán — dùng cho Telegram webhook (không cần set tay)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com

ORDERS_TAB=ORDERS
PRODUCTS_TAB=PRODUCTS
POOL_TAB=POOL
RESERVATIONS_TAB=RESERVATIONS
FULFILLMENTS_TAB=FULFILLMENTS
USERS_TAB=USERS
# Tab thông báo (trùng tên tab trên Google Sheet, ví dụ: notifications)
NOTIFICATIONS_TAB=notifications

ORDER_TTL_SECONDS=300
APP_TIMEZONE=Asia/Ho_Chi_Minh

BANK_CODE=BIDV
BANK_NAME=BIDV
BANK_OWNER=NGUYEN VAN MINH
BANK_NUMBER=
NOTE_TEMPLATE={order_id}

SEPAY_API_KEY=
# Đặt =1 NẾU và CHỈ NẾU bạn thực sự muốn chạy webhook/expire không cần auth (dev)
ALLOW_PUBLIC_SEPAY=
ALLOW_PUBLIC_EXPIRE=
CHECK_AMOUNT=1
ACCEPT_GATEWAYS=BIDV

SUPPORT_ADMIN_NAME=Nguyễn Văn Minh
SUPPORT_ZALO=0342324611
SUPPORT_ZALO_LINK=https://zalo.me/0342324611
SUPPORT_TELE=@minhgear5
SUPPORT_TELE_LINK=https://t.me/minhgear5

ADMIN_PASSWORD=your_admin_password
# Danh sách Telegram user ID là admin (cách nhau bằng dấu phẩy). Bắt buộc set nếu muốn nhận thông báo bot + dùng /mail /2fa.
ADMIN_IDS=
PORT=10000
API_BASE_URL=http://127.0.0.1:10000/api
USE_BOT_API=0
CATALOG_CACHE_TTL=45
SEPAY_PORT=8001

# === Security mới ===
# API key cho REST /api/* (POST /api/orders, /api/users, ...). Bắt buộc cho production.
SHOP_API_KEY=
# Đặt =1 NẾU và CHỈ NẾU bạn thực sự muốn /api/* không cần key (dev)
SHOP_API_ALLOW_ANON=
# Secret token Telegram gửi kèm mỗi webhook (chuỗi ngẫu nhiên 1-256 ký tự A-Z, a-z, 0-9, _, -)
TELEGRAM_WEBHOOK_SECRET=

# === Backup ===
BACKUP_DIR=backups
BACKUP_KEEP_DAYS=14
